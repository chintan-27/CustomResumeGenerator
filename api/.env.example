# LLM Configuration - Choose ONE of the following setups:

# ============================================
# Option 1: OpenAI (Default)
# ============================================
OPENAI_KEY=sk-your-openai-api-key-here

# ============================================
# Option 2: UF Navigator Toolkit
# ============================================
# LLM_BASE_URL=https://api.ai.ufl.edu/v1
# LLM_API_KEY=your-navigator-api-key
# LLM_MODEL=gpt-4o-mini

# ============================================
# Option 3: Azure OpenAI
# ============================================
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_API_KEY=your-azure-api-key
# LLM_MODEL=gpt-4o-mini

# ============================================
# Option 4: Local Ollama
# ============================================
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# ============================================
# Option 5: Any OpenAI-Compatible API
# ============================================
# LLM_BASE_URL=https://your-api-endpoint/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=model-name
